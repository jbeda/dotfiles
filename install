#!/usr/bin/env bash

# Logging stuff.
function e_header()   { echo -e "\n\033[1m$@\033[0m"; }
function e_success()  { echo -e " \033[1;32m✔\033[0m  $@"; }
function e_error()    { echo -e " \033[1;31m✖\033[0m  $@"; }
function e_arrow()    { echo -e " \033[1;33m➜\033[0m  $@"; }

# If backups are needed, this is where they'll go.
backup_dir="$HOME/.dotfiles-backups/$(date "+%Y_%m_%d-%H_%M_%S")/"
backup=

dotfile_base=~/src/dotfiles

# Based on https://github.com/cowboy/dotfiles/blob/master/bin/dotfiles
function do_stuff() {
  local base dest skip
  local files=($2/*)
  # No files? abort.
  if (( ${#files[@]} == 0 )); then return; fi
  # Run _header function only if declared.
  [[ $(declare -f "$1_header") ]] && "$1_header"
  # Iterate over files.
  for file in "${files[@]}"; do
    base="$(basename $file)"
    dest="$HOME/$base"
    # Run _test function only if declared.
    if [[ $(declare -f "$1_test") ]]; then
      # If _test function returns a string, skip file and print that message.
      skip="$("$1_test" "$file" "$dest")"
      if [[ "$skip" ]]; then
        e_error "Skipping ~/$base, $skip."
        continue
      fi
      # Destination file already exists in ~/. Back it up!
      if [[ -e "$dest" ]]; then
        e_arrow "Backing up ~/$base."
        # Set backup flag, so a nice message can be shown at the end.
        backup=1
        # Create backup dir if it doesn't already exist.
        [[ -e "$backup_dir" ]] || mkdir -p "$backup_dir"
        # Backup file / link / whatever.
        mv "$dest" "$backup_dir"
      fi
    fi
    # Do stuff.
    "$1_do" "$base" "$file"
  done
}

# Link files.
function link_header() { e_header "Linking files into home directory"; }
function link_test() {
  [[ "$1" -ef "$2" ]] && echo "same file"
}
function link_do() {
  e_success "Linking ~/$1."
  ln -sf ${2#$HOME/} ~/
}

# Link individual bin files into ~/.local/bin (keeps it a real dir so other
# tools -- pip/pipx/uv --user -- can write there too). Sources both the generic
# bin/ and the platform-specific $platform/bin/ (e.g. linux/bin holds the
# remote-side reverse-bridge tools that make no sense on the Mac).
function link_bin() {
  local dir files=()
  for dir in "$dotfile_base/bin" "$dotfile_base/$platform/bin"; do
    [[ -d "$dir" ]] && files+=("$dir"/*)
  done
  if (( ${#files[@]} == 0 )); then return; fi
  local bindir="$HOME/.local/bin"
  e_header "Linking files into ~/.local/bin"
  mkdir -p "$bindir"
  for file in "${files[@]}"; do
    local base="$(basename $file)"
    local dest="$bindir/$base"
    if [[ "$file" -ef "$dest" ]]; then
      e_error "Skipping ~/.local/bin/$base, same file."
      continue
    fi
    if [[ -e "$dest" ]]; then
      e_arrow "Backing up ~/.local/bin/$base."
      backup=1
      [[ -e "$backup_dir" ]] || mkdir -p "$backup_dir"
      mv "$dest" "$backup_dir"
    fi
    e_success "Linking ~/.local/bin/$base."
    ln -sf "$file" "$dest"
  done
}

# Link config files into ~/.config, mirroring the tree under config/ and the
# platform-specific $platform/config/ (e.g. darwin/config/ghostty/config ->
# ~/.config/ghostty/config). Directories are created for real -- ~/.config is
# shared with plenty of unmanaged tools -- and only leaf files are symlinked.
function link_config() {
  local dir entry file rel dest
  local entries=()
  for dir in "$dotfile_base/config" "$dotfile_base/$platform/config"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r -d '' file; do
      entries+=("$dir|$file")
    done < <(find "$dir" -type f -print0)
  done
  if (( ${#entries[@]} == 0 )); then return; fi
  e_header "Linking files into ~/.config"
  for entry in "${entries[@]}"; do
    dir="${entry%%|*}"; file="${entry#*|}"
    rel="${file#$dir/}"
    dest="$HOME/.config/$rel"
    if [[ "$file" -ef "$dest" ]]; then
      e_error "Skipping ~/.config/$rel, same file."
      continue
    fi
    if [[ -e "$dest" ]]; then
      e_arrow "Backing up ~/.config/$rel."
      backup=1
      [[ -e "$backup_dir" ]] || mkdir -p "$backup_dir"
      mv "$dest" "$backup_dir"
    fi
    mkdir -p "$(dirname "$dest")"
    e_success "Linking ~/.config/$rel."
    ln -sf "$file" "$dest"
  done
}

# Tweak file globbing.
shopt -s dotglob
shopt -s nullglob

platform=$(echo $(uname -s) | tr '[:upper:]' '[:lower:]')

# Bootstrap the Starship prompt if it's missing. The install is otherwise
# symlink-only, but source/50_prompt.sh needs the starship binary present
# (falls back to a bare prompt without it). Idempotent and non-fatal.
function install_starship() {
  command -v starship >/dev/null 2>&1 && { e_success "starship already installed."; return; }
  e_header "Installing starship prompt"
  if [[ "$platform" == "darwin" ]] && command -v brew >/dev/null 2>&1; then
    brew install starship
  elif command -v curl >/dev/null 2>&1; then
    mkdir -p "$HOME/.local/bin"
    curl -sS https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"
  else
    e_error "Can't install starship automatically: need brew (darwin) or curl. Install it manually."
  fi
}

# Bootstrap mise (runtime version manager -- node, etc.) if missing, then
# install the tools pinned in config/mise/config.toml. Must run after
# link_config so the global config is in place. Idempotent and non-fatal.
function install_mise() {
  local mise_bin
  if ! mise_bin="$(command -v mise)" && [[ ! -x "$HOME/.local/bin/mise" ]]; then
    e_header "Installing mise"
    if [[ "$platform" == "darwin" ]] && command -v brew >/dev/null 2>&1; then
      brew install mise
    elif command -v curl >/dev/null 2>&1; then
      curl -sS https://mise.run | sh
    else
      e_error "Can't install mise automatically: need brew (darwin) or curl. Install it manually."
      return
    fi
  else
    e_success "mise already installed."
  fi
  # command -v may miss ~/.local/bin in a bare bash env; fall back explicitly.
  mise_bin="$(command -v mise || echo "$HOME/.local/bin/mise")"
  if [[ -x "$mise_bin" ]]; then
    e_header "Installing mise-pinned runtimes"
    "$mise_bin" install
  fi
}

do_stuff "link" "$dotfile_base/link"
[ -d "$dotfile_base/$platform/link" ] && do_stuff "link" "$dotfile_base/$platform/link"
link_bin
link_config
install_starship
install_mise

# Alert if backups were made.
if [[ "$backup" ]]; then
  echo -e "\nBackups were moved to ~/${backup_dir#$HOME/}"
fi

# All done!
e_header "All done!"
