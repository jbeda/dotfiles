#!/usr/bin/env bash
# Clone a GitHub repo in bare+worktree layout for use with wt.
# Usage: wt-clone <git-url> [<dest-dir>]
#
# If <dest-dir> is omitted, the repo name is inferred from the URL and placed
# under ~/src/. The script sets up:
#   <dest>/         — project root
#   <dest>/.bare/   — bare clone
#   <dest>/.git     — file pointing at .bare so git works from the project root
#   <dest>/main/    — initial worktree for the default branch
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: wt-clone <git-url> [<dest-dir>]" >&2
  exit 1
fi

url="$1"

if [[ $# -ge 2 ]]; then
  dest="$2"
else
  # Infer project name from URL (strip .git suffix)
  name="$(basename "$url" .git)"
  dest="$HOME/src/$name"
fi

echo "Cloning $url → $dest"
mkdir -p "$dest"

git clone --bare "$url" "$dest/.bare"

# Let git commands work from the project root (outside any worktree)
echo "gitdir: ./.bare" > "$dest/.git"

# Ensure remote-tracking branches are fetched correctly
git -C "$dest/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
git -C "$dest/.bare" fetch origin

# Determine the default branch
default_branch="$(git -C "$dest/.bare" symbolic-ref --short HEAD 2>/dev/null || echo main)"

echo "Checking out $default_branch worktree"
wt -C "$dest/.bare" switch "$default_branch"

echo "Done. Your worktree is at $dest/$default_branch"
