#!/usr/bin/env bash
#
# browse -- open a URL in the browser on the OTHER end of the SSH connection
# (your Mac), via a reverse-forwarded port.
#
# Reads the URL from $1 or stdin and writes "open<TAB><url>" to
# 127.0.0.1:$MAC_BRIDGE_PORT, where an SSH RemoteForward tunnels it back to a
# launchd listener on the Mac that runs `open`. See darwin/mac-bridge/ for the
# Mac side + ssh config.
#
# Prints a hint and exits non-zero if the tunnel/listener isn't up.
set -euo pipefail

port="${MAC_BRIDGE_PORT:-17603}"
url="${1:-}"
[[ -n "$url" ]] || { IFS= read -r url || true; }
[[ -n "$url" ]] || { echo "browse: no URL given (pass as arg or on stdin)" >&2; exit 1; }

if ! exec 3<>"/dev/tcp/127.0.0.1/${port}" 2>/dev/null; then
  echo "browse: nothing is listening on 127.0.0.1:${port}." >&2
  echo "        Is the SSH RemoteForward active and the Mac listener loaded?" >&2
  echo "        See ~/src/dotfiles/darwin/mac-bridge/README.md" >&2
  exit 1
fi

# Shared secret gating the bridge (darwin/mac-bridge/dispatch). No token => empty
# field => the Mac rejects it (fail closed); run darwin/mac-bridge/set-token once.
tok=""
tokfile="${MAC_BRIDGE_TOKEN_FILE:-$HOME/.config/mac-bridge/token}"
if [[ -r "$tokfile" ]]; then IFS= read -r tok < "$tokfile" || true; fi

printf '%s\topen\t%s\n' "$tok" "$url" >&3
exec 3>&-
