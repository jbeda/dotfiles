#!/usr/bin/env bash
#
# setup-mac -- one-shot installer for the Mac side of the mac-bridge.
# Run this ON THE MAC (the SSH client). Idempotent; safe to re-run.
#
#   ./setup-mac [ssh-host-alias] [tailscale-fqdn]
#
# It installs + loads the launchd listener and the always-on autossh tunnel,
# migrates the old browser-bridge agent if present, self-tests the socket, and
# prints the ssh config blocks to add by hand. The optional args (e.g.
# `./setup-mac claudes-plan claudes-plan.tailXXXX.ts.net`) only make the printed
# hint concrete; it never edits any files.
set -euo pipefail

PORT=17603
LABEL="com.jbeda.mac-bridge"
TUNNEL_LABEL="com.jbeda.mac-bridge-tunnel"   # always-on autossh reverse tunnel
OLD_LABEL="com.jbeda.browser-bridge"   # pre-unification name; migrated below
here="$(cd "$(dirname "$0")" && pwd)"
plist_src="$here/$LABEL.plist"
plist_dest="$HOME/Library/LaunchAgents/$LABEL.plist"
tunnel_src="$here/$TUNNEL_LABEL.plist"
tunnel_dest="$HOME/Library/LaunchAgents/$TUNNEL_LABEL.plist"
ssh_host="${1:-claudes-plan}"
ts_fqdn="${2:-claudes-plan.<your-tailnet>.ts.net}"   # Tailscale MagicDNS FQDN

say()  { printf '\033[1;32m✔\033[0m  %s\n' "$1"; }
info() { printf '\033[1;33m➜\033[0m  %s\n' "$1"; }
die()  { printf '\033[1;31m✖\033[0m  %s\n' "$1" >&2; exit 1; }

[[ "$(uname -s)" == "Darwin" ]] || die "This is the Mac side; run it on macOS."
[[ -f "$plist_src" ]] || die "Can't find $plist_src"

# --- 0. Migrate the old browser-bridge agent, if it's still around ------
# It listened on the same port, so leaving it loaded would fight for the socket.
# Evict by label too: the agent may be registered from a plist loaded straight
# out of the repo (a path that no longer exists), which unload-by-file misses.
old_dest="$HOME/Library/LaunchAgents/$OLD_LABEL.plist"
if [[ -e "$old_dest" || -L "$old_dest" ]]; then
  launchctl unload "$old_dest" 2>/dev/null || true
  rm -f "$old_dest"
  say "Removed old $OLD_LABEL plist (unified into $LABEL)"
fi
if launchctl bootout "gui/$(id -u)/$OLD_LABEL" 2>/dev/null; then
  say "Evicted stale $OLD_LABEL registration from launchd"
fi

# --- 1. Install + (re)load the launchd listener -------------------------
# The plist just execs ./dispatch; make sure it's runnable (git preserves the
# bit, but a fresh copy/edit might not).
chmod +x "$here/dispatch" 2>/dev/null || true

mkdir -p "$HOME/Library/LaunchAgents"
ln -sfn "$plist_src" "$plist_dest"
say "Linked $plist_dest"

launchctl unload "$plist_dest" 2>/dev/null || true
launchctl load "$plist_dest"
say "Loaded launchd agent $LABEL"

# --- 2. Self-test the socket (nothing opened) ---------------------------
# A zero-I/O connect proves launchd is listening; the handler reads EOF, sees an
# empty verb, and dispatches nothing.
if nc -z 127.0.0.1 "$PORT" 2>/dev/null; then
  say "Listener answering on 127.0.0.1:$PORT"
else
  die "Nothing answered on 127.0.0.1:$PORT -- check: launchctl list | grep mac-bridge"
fi

# --- 3. Install + load the always-on reverse tunnel ---------------------
# The listener above only receives; something has to keep port 17603 forwarded
# from the box back to it. Historically that rode your interactive ssh session
# (RemoteForward in the Host block), so it died the moment sleep or a network
# change dropped that session. This dedicated autossh tunnel owns the forward and
# redials itself, so the bridge is up whenever the Mac can reach the box.
if command -v autossh >/dev/null 2>&1; then
  ln -sfn "$tunnel_src" "$tunnel_dest"
  say "Linked $tunnel_dest"
  launchctl unload "$tunnel_dest" 2>/dev/null || true
  launchctl load "$tunnel_dest"
  say "Loaded always-on tunnel agent $TUNNEL_LABEL (logs: /tmp/mac-bridge-tunnel.log)"
else
  info "autossh NOT found -- the always-on bridge tunnel needs it:"
  info "  brew install autossh   # then re-run this script to load the tunnel"
fi

# --- 4. Print the ssh config blocks to add by hand ----------------------
# Editing ~/.ssh/config automatically is fiddly (multi-name Host lines, merging
# into an existing block), and this is a rare one-time step -- so just print the
# lines and let you drop them in yourself. Two blocks now:
#   - your interactive/VS Code block: keepalives + ControlMaster, but NO
#     RemoteForward (the tunnel owns it -- two owners would collide on 17603).
#   - a dedicated `${ssh_host}-tunnel` block the autossh job dials: it carries
#     the RemoteForward, dies loudly if it can't bind (so autossh redials), and
#     never multiplexes (stays independent of your sessions).
info "1) In your existing 'Host $ssh_host' block: set HostName to your Tailscale"
info "   MagicDNS FQDN ($ts_fqdn), add these keepalives, and"
info "   REMOVE any 'RemoteForward $PORT ...' line (the tunnel block below owns it):"
cat <<EOF

    HostName $ts_fqdn
    ForwardAgent yes
    ControlMaster auto
    ControlPath ~/.ssh/cm-%C
    ControlPersist 10m
    ServerAliveInterval 20
    ServerAliveCountMax 3
    TCPKeepAlive yes

EOF
info "2) Add this NEW dedicated tunnel block. Keep the alias exactly"
info "   'claudes-plan-tunnel' -- the launchd plist dials that literal name."
info "   HostName is the Tailscale FQDN so it routes on every network you roam to:"
cat <<EOF

Host claudes-plan-tunnel
    HostName $ts_fqdn
    ForwardAgent no
    ControlMaster no
    ControlPath none
    RemoteForward $PORT 127.0.0.1:$PORT
    ExitOnForwardFailure yes
    ServerAliveInterval 20
    ServerAliveCountMax 3

EOF
info "3) On the BOX, add matching server-side keepalives (one time, needs sudo):"
info "     sudo tee /etc/ssh/sshd_config.d/10-keepalive.conf >/dev/null <<'CONF'"
info "     ClientAliveInterval 20"
info "     ClientAliveCountMax 3"
info "     TCPKeepAlive yes"
info "     CONF"
info "     sudo sshd -t && sudo systemctl reload ssh"
info "Then reconnect. Also install VS Code's 'code' CLI on PATH (Command Palette"
info "-> Shell Command: Install 'code' command in PATH) and the Remote - SSH ext."

# --- 5. Dependency check for the clip-image verb ------------------------
# `paste-image` (box) -> clip-image (here) needs pngpaste to read the clipboard.
if command -v pngpaste >/dev/null 2>&1; then
  say "pngpaste found -- the clip-image verb (box: paste-image) will work"
else
  info "pngpaste NOT found -- 'paste-image' from the box won't work until you:"
  info "  brew install pngpaste"
fi

say "Done. From the box:  browse <url>  |  code-mac [dir]  |  paste-image (C-Spc i in tmux)"
