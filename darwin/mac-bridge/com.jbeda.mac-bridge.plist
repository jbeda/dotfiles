<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jbeda.mac-bridge</string>

  <!-- inetd-style: launchd listens on the socket, accepts each connection,
       and runs the program once per connection with the socket wired to
       stdin/stdout. No long-running daemon, no polling. -->
  <key>inetdCompatibility</key>
  <dict>
    <key>Wait</key>
    <false/>
  </dict>

  <key>Sockets</key>
  <dict>
    <key>Listeners</key>
    <dict>
      <!-- Bound to loopback: only the SSH reverse tunnel (which lands on the
           Mac's localhost) can reach it. -->
      <key>SockNodeName</key>
      <string>127.0.0.1</string>
      <key>SockServiceName</key>
      <string>17603</string>
      <key>SockType</key>
      <string>stream</string>
      <key>SockFamily</key>
      <string>IPv4</string>
    </dict>
  </dict>

  <!-- Hand each accepted connection to the on-disk dispatch script, which reads
       one tab-separated request line ("verb TAB args") off the socket (stdin)
       and validates + runs it. The logic lives in ./dispatch (three verbs:
       open / code / clip-image) rather than inline here so it stays readable and
       lintable. We exec it via $HOME (expanded by sh) so the plist needn't
       hardcode an absolute home path; it assumes the repo is at ~/src/dotfiles,
       same as the resurrect/continuum hooks in .tmux.conf. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>exec "$HOME/src/dotfiles/darwin/mac-bridge/dispatch"</string>
  </array>
</dict>
</plist>
