#!/usr/bin/env bash
#
# setup-mac -- one-shot installer for the Mac side of the browser bridge.
# Run this ON THE MAC (the SSH client). Idempotent; safe to re-run.
#
#   ./setup-mac [ssh-host-alias]
#
# With no argument it installs + loads the launchd listener and self-tests it,
# then prints the ssh_config line to add. Pass your Host alias for the remote
# box (e.g. `./setup-mac claudes-plan`) to also append the RemoteForward to
# ~/.ssh/config automatically.
set -euo pipefail

PORT=17603
LABEL="com.jbeda.browser-bridge"
here="$(cd "$(dirname "$0")" && pwd)"
plist_src="$here/$LABEL.plist"
plist_dest="$HOME/Library/LaunchAgents/$LABEL.plist"
ssh_host="${1:-}"

say()  { printf '\033[1;32m✔\033[0m  %s\n' "$1"; }
info() { printf '\033[1;33m➜\033[0m  %s\n' "$1"; }
die()  { printf '\033[1;31m✖\033[0m  %s\n' "$1" >&2; exit 1; }

[[ "$(uname -s)" == "Darwin" ]] || die "This is the Mac side; run it on macOS."
[[ -f "$plist_src" ]] || die "Can't find $plist_src"

# --- 1. Install + (re)load the launchd listener -------------------------
mkdir -p "$HOME/Library/LaunchAgents"
ln -sfn "$plist_src" "$plist_dest"
say "Linked $plist_dest"

launchctl unload "$plist_dest" 2>/dev/null || true
launchctl load "$plist_dest"
say "Loaded launchd agent $LABEL"

# --- 2. Self-test the socket (no browser tab opened) --------------------
# A zero-I/O connect proves launchd is listening; the handler reads EOF, sees
# an empty URL, and opens nothing.
if nc -z 127.0.0.1 "$PORT" 2>/dev/null; then
  say "Listener answering on 127.0.0.1:$PORT"
else
  die "Nothing answered on 127.0.0.1:$PORT -- check: launchctl list | grep browser-bridge"
fi

# --- 3. Wire up the ssh RemoteForward -----------------------------------
fwd_line="    RemoteForward $PORT 127.0.0.1:$PORT"
if [[ -n "$ssh_host" ]]; then
  cfg="$HOME/.ssh/config"
  marker="# browser-bridge:$ssh_host"
  mkdir -p "$HOME/.ssh"; touch "$cfg"; chmod 600 "$cfg"
  if grep -qF "$marker" "$cfg"; then
    say "ssh RemoteForward for '$ssh_host' already present in ~/.ssh/config"
  else
    {
      printf '\n%s (managed) >>>\n' "$marker"
      printf 'Host %s\n%s\n' "$ssh_host" "$fwd_line"
      printf '%s (managed) <<<\n' "$marker"
    } >> "$cfg"
    say "Appended RemoteForward for '$ssh_host' to ~/.ssh/config"
  fi
  info "Reconnect your SSH session for the forward to take effect."
else
  info "No host alias given. Add this to the host's block in ~/.ssh/config:"
  printf '\n    Host <your-remote-alias>\n    %s\n\n' "$fwd_line"
  info "Or re-run: ./setup-mac <your-remote-alias> to do it automatically."
fi

say "Done. From the remote box: browse https://example.com"
